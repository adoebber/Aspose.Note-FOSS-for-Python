; =============================================================================
; 15. COMPLEX TYPES — MS-ONE section 2.2
; =============================================================================

Color:
  description: 4-byte ABGR color value
  fields[4]{name,size,type}:
    red, 1 byte, uint8
    green, 1 byte, uint8
    blue, 1 byte, uint8
    alpha, 1 byte, uint8 — 0xFF=opaque\, 0x00=automatic/default

COLORREF:
  description: 4-byte RGB color (Windows COLORREF)
  fields[4]{name,size,type}:
    red, 1 byte, uint8
    green, 1 byte, uint8
    blue, 1 byte, uint8
    reserved, 1 byte, uint8 — MUST be zero

FontColor:
  description: 4-byte font color with auto-detection
  note: If alpha=0xFF\, color is explicit (RGB). If alpha=0x00\, use automatic color.

WzInAtom:
  description: UTF-16LE null-terminated string inside prtFourBytesOfLengthFollowedByData
  encoding: UTF-16LE
  terminator: 0x0000 (null char)

Time32:
  description: 4-byte timestamp — minutes since January 1\, 1601 00:00:00 UTC
  fields[1]{name,size,type}:
    value, 4 bytes, uint32 — minutes since epoch

; =============================================================================
; 16. DOCUMENT OBJECT MODEL HIERARCHY — MS-ONE
; =============================================================================

; --- .one file hierarchy ---
; SectionObjectSpace (root)
;   └─ jcidSectionNode (default content root)
;       ├─ ElementChildNodesOfSection → jcidPageSeriesNode[]
;       │   ├─ MetaDataObjectsAboveGraphSpace → jcidPageMetaData[]
;       │   │   note: preserves page ordering, cached titles, and PageLevel/subpage hierarchy for the series
;       │   └─ page content may reside in separate page object spaces rather than as direct PageNode children of the section object space
;       │       mapping guidance: correlate PageSeries/PageMetaData records with page object spaces through NotebookManagementEntityGuid and topology ordering
;       ├─ separate PageObjectSpace(s)
;       │   └─ jcidPageManifestNode / jcidPageNode
;       │       ├─ jcidTitleNode (optional)
;       │       │   └─ jcidOutlineNode (IsTitleText=true)
