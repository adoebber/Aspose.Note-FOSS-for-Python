;       │       │       │                                    → jcidTableNode
;       │       │       └─ ElementChildNodesOfOutlineElement → jcidOutlineElementNode[] (nested)
;       │       └─ StructureElementChildNodes → jcidTitleNode
;       └─ jcidSectionMetaData (metadata root)
;   └─ jcidPageMetaData (per-page metadata root, frequently attached above a PageSeries graph and mirrored in page object spaces)

