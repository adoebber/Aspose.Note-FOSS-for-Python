    TextRun:
      kind: dataclass
      base: Node
      members:
        Text: {type:str,default:'',logic:text slice belonging to this run}
        Style: {type:TextStyle,default:TextStyle(),logic:run-level style object}
        Start: {type:int|None,default:null,logic:inclusive start offset in parent RichText.Text}
        End: {type:int|None,default:null,logic:exclusive end offset in parent RichText.Text}

    RichText:
      kind: dataclass
      base: CompositeNode
      members:
        Text: {type:str,default:'',logic:plain text content}
        Runs: {type:list[TextRun],default:[],logic:optional style segmentation metadata}
        ParagraphStyle: {type:TextStyle,default:TextStyle(),logic:paragraph-level fallback style used when run style does not supply a setting}
        FontSize: {type:float|None,default:null,logic:fallback font size}
        LastModifiedTime: {type:datetime|None,default:null,logic:reserved compatibility member; current loader does not populate it}
        SpaceBefore: {type:float|None,default:null,logic:reserved compatibility member for paragraph spacing before text}
        SpaceAfter: {type:float|None,default:null,logic:reserved compatibility member for paragraph spacing after text}
        LineSpacing: {type:float|None,default:null,logic:reserved compatibility member for line spacing}
        Tags: {type:list[NoteTag],default:[],logic:tag metadata associated with text}
      properties:
        TextRuns: {type:sequence<TextRun>,logic:alias to Runs using the canonical public member name}
        Length: {type:int,logic:returns len(Text)}
        Alignment: {type:HorizontalAlignment|None,logic:reads paragraph alignment from ParagraphStyle first and then from run styles; setting it updates ParagraphStyle and fills missing run alignments}
        IsTitleText: {type:bool,logic:true when this node is the Title.TitleText child of its parent Title}
        IsTitleDate: {type:bool,logic:true when this node is the Title.TitleDate child of its parent Title}
        IsTitleTime: {type:bool,logic:true when this node is the Title.TitleTime child of its parent Title}
      methods:
        Append:
          signature: (text:str, style:TextStyle|None=None) -> RichText
          logic[3]:
            appends text argument to Text string
            if style is provided then appends TextRun(Text=text,Style=style) to Runs
            returns self for fluent chaining
        AppendFront:
          signature: (text:str, style:TextStyle|None=None) -> RichText
          logic: inserts text at the beginning and returns self
        Clear:
          signature: () -> RichText
          logic: clears Text and Runs and returns self
        GetEnumerator:
          signature: () -> Iterator[str]
          logic: returns iterator over characters of Text
        Insert:
          signature: (index:int, text:str, style:TextStyle|None=None) -> RichText
          logic: inserts text at bounded index, normalizes current run model to a single run, and returns self
        Remove:
          signature: (start:int, count:int|None=None) -> RichText
          logic: removes text from bounded range, normalizes current run model to a single run when needed, and returns self
        Replace:
          signature: (old_value:str, new_value:str, style:TextStyle|None=None) -> RichText
          logic[4]:
            rejects invalid arguments when old_value is empty or when a required string argument is null, using the target language's standard argument-validation exception model
            replaces all occurrences of old_value in Text with new_value
            when style is provided replacement result is represented by a single TextRun using that style
            returns self for fluent chaining
        Trim:
          signature: () -> RichText
          logic: trims leading and trailing whitespace from Text and returns self
        TrimStart:
          signature: () -> RichText
          logic: trims leading whitespace from Text and returns self
        TrimEnd:
          signature: () -> RichText
          logic: trims trailing whitespace from Text and returns self

