    Page:
      kind: dataclass
      base: CompositeNode
      members:
        Title: {type:Title|None,default:null,logic:page title object reference}
        Author: {type:str|None,default:null,logic:page author}
        CreationTime: {type:datetime|None,default:null,logic:page creation timestamp}
        LastModifiedTime: {type:datetime|None,default:null,logic:page modification timestamp}
        Level: {type:int|None,default:null,logic:page hierarchy level}
        BackgroundColor: {type:int|None,default:null,logic:reserved compatibility member}
        Margin: {type:Any|None,default:null,logic:reserved compatibility member}
        SizeType: {type:Any|None,default:null,logic:reserved compatibility member}
        PageLayoutSize: {type:Any|None,default:null,logic:reserved compatibility member}
        IsConflictPage: {type:bool,default:false,logic:reserved compatibility member}
        PageContentRevisionSummary: {type:Any|None,default:null,logic:reserved compatibility member}
      methods:
        Clone:
          signature: (cloneHistory:boolean=false, compatibility_options:object|null=null) -> Page
          logic[3]:
            performs a deep structural clone of the page subtree and resets ParentNode of the clone root to null
            cloneHistory parameter is accepted for compatibility with the canonical public contract, but page-history objects are not modeled separately in the current implementation
            compatibility-only options may be accepted and mapped onto the cloneHistory behavior by a concrete runtime

    Document:
      kind: dataclass_like
      base: CompositeNode
      constructor:
        signature: (source:string|path|stream|null=null, load_options:LoadOptions|null=null)
        logic[8]:
          initializes DisplayName and CreationTime to null
          if source is null returns empty Document
          if load_options.DocumentPassword is provided raises IncorrectPasswordException
          imports internal onenote parser lazily
          loads parser document by path (onenote.Document.open) for str/Path source
          loads parser document by stream (onenote.Document.from_stream) otherwise
          stores loaded document display name in DisplayName
          converts each parsed page and appends to children
      members:
        DisplayName:
          type: str|None
          default: null
          logic: populated from underlying parser document when loaded from source
        CreationTime:
          type: datetime|None
          default: null
          logic: currently not assigned in constructor
      properties:
        FileFormat:
          type: FileFormat
          logic: always returns FileFormat.OneNote2010
      methods:
        Count:
          signature: () -> int
          logic: returns len(_children)
        DetectLayoutChanges:
          signature: () -> None
          logic: no-op compatibility method
        GetPageHistory:
          signature: (page:Page) -> list[Page]
          logic: returns single-item list containing provided page
        Save:
          signature: (target:str|Path|BinaryIO, format_or_options:Any=None) -> None
          format_resolution_logic[5]:
            if format_or_options is null and target is a file path with .pdf extension then use SaveFormat.Pdf
            if format_or_options is null and target is stream-like then use SaveFormat.Pdf
            if format_or_options equals SaveFormat.Pdf then use SaveFormat.Pdf
            if format_or_options is PdfSaveOptions then use SaveFormat.Pdf with those options
            if format_or_options is SaveOptions and opts.SaveFormat equals SaveFormat.Pdf then use SaveFormat.Pdf
            otherwise raise UnsupportedSaveFormatException('Only PDF save is supported')
          execution_logic:
            steps[3]:
              render current public DOM to PDF bytes using the current renderer
              if options is PdfSaveOptions honor the currently supported subset (PageIndex, PageCount, TagIconDir, TagIconSize, TagIconGap)
              write produced bytes to file path or stream target
